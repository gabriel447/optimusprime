# Binance Testnet API credentials
# Gerar em: https://testnet.binance.vision/
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# Par e timeframe a operar (ex.: BTC/USDT no timeframe de 15 minutos)
SYMBOL=BTC/USDT
TIMEFRAME=15m

# Quantidade de candles mantidos em memória para análise
CANDLE_HISTORY_SIZE=300

# Intervalo de polling de novos candles (ms)
POLL_INTERVAL_MS=5000

# Valor nominal arriscado por operação em USDT (usado para dimensionar a posição)
RISK_PER_TRADE_USDT=25

# Quantidade máxima de candles que uma posição pode ficar aberta sem bater stop/alvo.
# Ao atingir esse limite, o bot cancela stop+alvo e fecha a mercado (outcome='timeout').
# 0 = desativado.
MAX_CANDLES_PER_TRADE=0

# Porta do servidor HTTP/WebSocket
SERVER_PORT=3001

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Se 'true', o bot apenas gera sinais e não envia ordens (paper trading)
DRY_RUN=true
